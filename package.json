{
	"name": "atom-hospital-monorepo",
	"description": "Healthcare appointment booking platform - monorepo",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.18.1",
	"scripts": {
		"dev": "pnpm -r --parallel run dev",
		"build": "pnpm -r run build",
		"start": "pnpm -r run start",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "pnpm -r run check",
		"format": "biome format .",
		"typecheck": "pnpm -r run typecheck",
		"db:generate": "pnpm -F @repo/db run generate",
		"db:migrate": "pnpm -F @repo/db run migrate",
		"db:push": "pnpm -F @repo/db run push",
		"db:studio": "pnpm -F @repo/db run studio"
	},
	"dependencies": {
		"@trpc/client": "^11.16.0",
		"@trpc/react-query": "^11.16.0",
		"@trpc/server": "^11.16.0",
		"superjson": "^2.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5"
	}
}
